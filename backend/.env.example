# Database
DATABASE_URL=mysql+asyncmy://goat_admin:GoatAdmin@2024@db:3306/goat_insurance
DATABASE_URL_SYNC=mysql+pymysql://goat_admin:GoatAdmin@2024@db:3306/goat_insurance

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
APP_NAME=Goat Insurance Management System
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Firebase
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# OTP
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
